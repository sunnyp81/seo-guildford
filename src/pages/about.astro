---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';

const title = "About SEO Guildford: Guildford Search Consultancy";
const description = "SEO Guildford is a specialist search consultancy serving Guildford, Surrey and Hampshire. Data-driven methodology, technical precision, and AI-search expertise for discerning businesses.";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://seo-guildford.uk/" },
    { "@type": "ListItem", "position": 2, "name": "About", "item": "https://seo-guildford.uk/about/" }
  ]
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://seo-guildford.uk/about/",
  "isPartOf": { "@type": "WebSite", "name": "SEO Guildford", "url": "https://seo-guildford.uk" }
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "SEO Guildford",
  "url": "https://seo-guildford.uk",
  "email": "hello@seo-guildford.uk",
  "sameAs": ["https://find-and-update.company-information.service.gov.uk/company/10784524"],
  "areaServed": [
    { "@type": "City", "name": "Guildford" },
    { "@type": "AdministrativeArea", "name": "Surrey" },
    { "@type": "AdministrativeArea", "name": "Hampshire" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What methodology does SEO Guildford follow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every engagement begins with a thorough technical audit and competitive analysis grounded in first-party data from Google Search Console and Bing Webmaster Tools. I prioritise technical foundations, crawl efficiency, structured data, Core Web Vitals, before addressing content and authority. Recommendations are evidence-based, not speculative, and each action is measured against commercial outcomes rather than vanity metrics."
      }
    },
    {
      "@type": "Question",
      "name": "Why is SEO Guildford based in Guildford?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Guildford occupies a distinctive position in Surrey's commercial landscape. Surrey Research Park, the University of Surrey, and a well-established gaming and technology cluster create a business community that values technical rigour. The affluent demographics and competitive local market demand specialist SEO capability that generalist agencies are not equipped to provide."
      }
    },
    {
      "@type": "Question",
      "name": "Does SEO Guildford work with clients outside Surrey?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. While my primary service area encompasses Guildford, Woking, Godalming, Farnham, Camberley, and Cobham, I operate remote-first and serve clients nationally and internationally. Communication takes place via video call and shared dashboards, ensuring the same standard of service regardless of location."
      }
    },
    {
      "@type": "Question",
      "name": "What distinguishes SEO Guildford from larger agencies?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SEO Guildford is a specialist, solo consultancy, not a volume agency. There is no account manager layer, no junior staff learning on your account, and no templated deliverables. Every recommendation is drawn from your specific data, your competitive landscape, and your commercial objectives. The person who diagnoses the problem is the person who implements the solution."
      }
    },
    {
      "@type": "Question",
      "name": "How does SEO Guildford stay current with algorithm changes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "I run and monitor a range of SEO properties across multiple verticals, which provides continuous real-time signal data during every Google and Bing update. This hands-on exposure is supplemented by daily monitoring of Search Console, Webmaster Tools, and industry research. I also track AI search platforms, ChatGPT, Perplexity, Google AI Overviews, for citation patterns and emerging ranking factors."
      }
    }
  ]
};

const schema = [breadcrumbSchema, webPageSchema, orgSchema, faqSchema];
---

<Base title={title} description={description} canonical="https://seo-guildford.uk/about/" schema={schema} ogType="website">
  <section class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-text-muted mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-brand">Home</a>
      <span class="mx-1">/</span>
      <span class="text-text">About</span>
    </nav>

    <p class="eyebrow mb-4">About</p>
    <h1 class="text-4xl font-bold text-brand mb-6">About SEO <span class="mark">Guildford</span></h1>

    <div class="prose">
      <div class="reveal">
      <p>Good search optimisation resembles cartography more than salesmanship. It begins with surveying the terrain, the technical architecture of a site, the competitive contours of a market, the shifting currents of how people actually search, and only then charting a route forward. SEO Guildford is a specialist search consultancy that applies this principle across Guildford, Surrey, and Hampshire, delivering measurable improvements in organic visibility for both traditional search engines and the emerging AI-driven landscape.</p>

      <div class="quick-answer">
        <strong>The short version:</strong> SEO Guildford is a Guildford-based search consultancy built on data-driven methodology, technical rigour, and AI-search expertise. I work directly with business owners who expect substantive results rather than agency platitudes. No account managers, no outsourced work, no wasted spend.
      </div>
      </div>

      <div class="reveal">
      <h2>My Philosophy</h2>

      <p>I believe that effective search optimisation begins with honest assessment and ends with commercial impact. Between those two points lies a craft that demands technical fluency, analytical patience, and a willingness to challenge assumptions, including my own. Think of it as tending a garden rather than erecting a billboard: the work is ongoing, the results compound over time, and shortcuts invariably cost more than they save.</p>

      <p>My methodology is grounded in first-party data. Before any strategy takes shape, I conduct a thorough technical audit, analyse search console data across both Google and Bing, and map the competitive landscape with the kind of precision a surveyor would bring to unfamiliar ground. Recommendations emerge from evidence, not convention. Every action I take is calibrated against a single question: will this generate revenue, leads, or bookings that justify the investment?</p>

      <p>This approach reflects a broader conviction. Rankings and traffic are intermediate signals, necessary but insufficient. Impressions without clicks, rankings for terms that never convert, traffic that fails to translate into enquiries: these are vanity metrics, and I identify and deprioritise them early. What matters is the commercial outcome, and I structure every engagement around that principle.</p>
      </div>

      <div class="reveal">
      <h2>Why Guildford</h2>

      <p>Guildford is not a typical market, and I did not choose it arbitrarily. The town combines an affluent consumer base with a technically literate business community, one that understands digital marketing in broad terms but often lacks the specialist in-house SEO capability required to compete effectively.</p>

      <p>Surrey Research Park, adjacent to the University of Surrey campus, houses over 110 companies working in sectors from satellite technology to pharmaceutical research. These are organisations with complex technical products, extended sales cycles, and search intent patterns that demand specialist understanding rather than generic agency playbooks. The same is true of the professional services firms along Guildford High Street, and the solicitors, accountants, and consultancies serving the wider Surrey corridor.</p>

      <p>The gaming industry adds a distinctive dimension. Studios such as Media Molecule and Hello Games have established Guildford as a recognised hub for interactive entertainment. The creative and technology talent this attracts means local businesses are more likely to invest in digital channels, and more likely to hold their search provider to an exacting technical standard. I welcome that expectation.</p>

      <p>Beyond the town itself, the surrounding communities of Woking, Godalming, Farnham, Camberley, and Cobham extend my natural catchment. Each possesses its own commercial character, but they share proximity to the A3 and M25 corridors and a customer base that researches online before making purchasing decisions. For service businesses in this region, local search visibility is not an optional enhancement. It is the primary acquisition channel.</p>

      <p>Guildford Cathedral, visible from much of the town as it sits on Stag Hill, overlooks a market that rewards those who invest properly in their online presence. The competition is real, and that is precisely why specialist search consultancy matters here.</p>
      </div>

      <div class="reveal">
      <h2>My Approach</h2>

      <p>I structure my work around three interconnected disciplines, each reinforcing the others in much the same way that the foundations, walls, and roof of a well-designed building depend on one another. Technical soundness creates the conditions for content to perform; content performance generates the authority signals that strengthen technical standing; and AI-search readiness ensures visibility across the platforms that are increasingly mediating the relationship between businesses and their prospective customers.</p>

      <h3>Technical-First</h3>

      <p>Most search performance problems are, at their root, technical problems, a truth that many agencies prefer to obscure beneath layers of content strategy. A site that Google cannot crawl efficiently, that loads slowly on mobile devices, or that sends conflicting signals through duplicate content and broken canonical chains will underperform regardless of how accomplished the writing may be. I address technical SEO first because it removes the ceiling on everything else.</p>

      <p>In practice, this means examining crawl budgets, indexation patterns, internal linking architecture, structured data validity, Core Web Vitals scores, and server response behaviour. These are not optional refinements to be considered once content strategy is in place. They are the foundation upon which all subsequent work depends.</p>

      <h3>AI-Search Aware</h3>

      <p>The search landscape is undergoing a structural transformation. Google AI Overviews, ChatGPT with browsing capability, Perplexity, and Microsoft Copilot are reshaping how users discover and consume information. Businesses that optimise solely for traditional blue-link rankings are already ceding ground, like shops that refused to list a telephone number when directories first appeared.</p>

      <p>I build AI search readiness into every engagement. This encompasses entity optimisation, structured data that AI systems can parse reliably, content architecture designed for extraction and citation, and positioning strategies that establish my clients as trusted sources across AI platforms. Further detail is available on my <a href="/ai-search-optimisation-guildford/">AI search optimisation</a> page.</p>

      <h3>Transparent Reporting</h3>

      <p>I do not produce reports filled with jargon designed to obscure a lack of progress. My reporting covers what was done, what changed as a consequence, and what I intend to do next. Google Search Console and Bing Webmaster Tools data is shared directly. Questions are answered promptly and candidly. If something is not working, I will raise it before you need to ask.</p>
      </div>

      <div class="reveal">
      <h2>What I Specialise In</h2>

      <div class="grid md:grid-cols-2 gap-4 not-prose my-8">
        <a href="/technical-seo-guildford/" class="service-card reveal block" style="--reveal-delay: 0.08s">
          <span class="eyebrow block mb-2">01</span>
          <h3 class="font-semibold text-brand text-lg mb-2">Technical SEO</h3>
          <p class="text-text-muted text-sm">Site architecture, crawl optimisation, Core Web Vitals, structured data, indexation management, and migration support. The foundation that makes everything else work.</p>
        </a>
        <a href="/ai-search-optimisation-guildford/" class="service-card reveal block" style="--reveal-delay: 0.16s">
          <span class="eyebrow block mb-2">02</span>
          <h3 class="font-semibold text-brand text-lg mb-2">AI Search Optimisation</h3>
          <p class="text-text-muted text-sm">AEO and GEO strategies that position your brand for citations in ChatGPT, Perplexity, Google AI Overviews, and Copilot. Entity-first, data-structured, citation-driven.</p>
        </a>
        <a href="/services/" class="service-card reveal block" style="--reveal-delay: 0.24s">
          <span class="eyebrow block mb-2">03</span>
          <h3 class="font-semibold text-brand text-lg mb-2">Local SEO</h3>
          <p class="text-text-muted text-sm">Google Business Profile optimisation, local pack rankings, location-page strategy, review management, and citation building for Guildford and Surrey businesses.</p>
        </a>
        <a href="/services/" class="service-card reveal block" style="--reveal-delay: 0.32s">
          <span class="eyebrow block mb-2">04</span>
          <h3 class="font-semibold text-brand text-lg mb-2">Content Strategy</h3>
          <p class="text-text-muted text-sm">Topical authority mapping, keyword clustering, content briefs, and editorial calendars built around search demand and competitive gaps. Every page earns its place.</p>
        </a>
        <a href="/services/" class="service-card reveal block md:col-span-2" style="--reveal-delay: 0.40s">
          <span class="eyebrow block mb-2">05</span>
          <h3 class="font-semibold text-brand text-lg mb-2">E-Commerce SEO</h3>
          <p class="text-text-muted text-sm">Product page optimisation, faceted navigation handling, category architecture, and structured data for rich results. Built for platforms from Shopify to custom builds.</p>
        </a>
      </div>

      <p>Full details of all available services are on the <a href="/services/">services page</a>.</p>
      </div>

      <div class="reveal">
      <h2>Working With Me</h2>

      <p>The process is straightforward, because I believe clarity at the outset prevents friction later. An initial conversation establishes your goals, current performance, and competitive position. If there is a mutual fit, I provide a proposal within 48 hours that outlines scope, deliverables, timeline, and pricing, with no ambiguity and no hidden costs.</p>

      <h3>Communication</h3>

      <p>I value directness and efficiency in equal measure. You will have a direct line to me, not a support queue. Updates are regular but not excessive. When something requires your attention, I will raise it. When work is progressing as planned, I will not interrupt with unnecessary status emails.</p>

      <h3>What My Clients Can Expect</h3>

      <p>A clear plan of action within the first fortnight. Technical issues identified and prioritised by commercial impact. Content recommendations substantiated by search demand data. Monthly reporting that addresses the metrics you care about, rankings, traffic, conversions, and revenue. No lock-in contracts. My work either delivers results or it does not, and you are free to decide accordingly.</p>

      <p>Many engagements begin with a <a href="/free-seo-audit-guildford/">free SEO audit</a> that identifies the highest-impact opportunities before any commitment is made.</p>
      </div>

      <div class="reveal">
      <h2>Experience and Credentials</h2>

      <p>I bring extensive experience across agency, in-house, and consultancy settings, working hands-on across professional services, e-commerce, health and wellness, property, education, and technology. This is not a peripheral endeavour. It is a full-time practice built on continuous execution and rigorous measurement.</p>

      <p>My technical toolkit includes Google Search Console, Bing Webmaster Tools, Ahrefs, Screaming Frog, and programmatic SEO tooling. I've worked hands-on across sites ranging from small service businesses to large, complex platforms. Structured data implementation, site migrations, penalty recovery, and core update response all fall within my regular scope of work.</p>

      <p>The shift toward AI-mediated search is not something I am observing from the periphery. Active monitoring of how AI platforms select and cite sources, ongoing testing of entity optimisation strategies, and real-world tracking of AI Overview appearances across client queries inform every recommendation I make. Businesses near the University of Surrey and Surrey Research Park are already asking how AI search will affect their visibility. The candid answer is that it already has.</p>

      <p>Guildford businesses deserve a search consultancy that understands both the local market and the technical landscape in equal depth. That is what SEO Guildford provides.</p>
      </div>

      <div class="reveal">
      <h2>Frequently Asked Questions</h2>

      <details class="faq-item">
        <summary>What methodology does SEO Guildford follow?</summary>
        <p>Every engagement begins with a thorough technical audit and competitive analysis grounded in first-party data from Google Search Console and Bing Webmaster Tools. I prioritise technical foundations, crawl efficiency, structured data, Core Web Vitals, before addressing content and authority. Recommendations are evidence-based, not speculative, and each action is measured against commercial outcomes rather than vanity metrics.</p>
      </details>

      <details class="faq-item">
        <summary>Why is SEO Guildford based in Guildford?</summary>
        <p>Guildford occupies a distinctive position in Surrey's commercial landscape. Surrey Research Park, the University of Surrey, and a well-established gaming and technology cluster create a business community that values technical rigour. The affluent demographics and competitive local market demand specialist SEO capability that generalist agencies are not equipped to provide.</p>
      </details>

      <details class="faq-item">
        <summary>Does SEO Guildford work with clients outside Surrey?</summary>
        <p>Yes. While my primary service area encompasses Guildford, Woking, Godalming, Farnham, Camberley, and Cobham, I operate remote-first and serve clients nationally and internationally. Communication takes place via video call and shared dashboards, ensuring the same standard of service regardless of location.</p>
      </details>

      <details class="faq-item">
        <summary>What distinguishes SEO Guildford from larger agencies?</summary>
        <p>SEO Guildford is a specialist, solo consultancy, not a volume agency. There is no account manager layer, no junior staff learning on your account, and no templated deliverables. Every recommendation is drawn from your specific data, your competitive landscape, and your commercial objectives. The person who diagnoses the problem is the person who implements the solution.</p>
      </details>

      <details class="faq-item">
        <summary>How does SEO Guildford stay current with algorithm changes?</summary>
        <p>I run and monitor a range of SEO properties across multiple verticals, which provides continuous real-time signal data during every Google and Bing update. This hands-on exposure is supplemented by daily monitoring of Search Console, Webmaster Tools, and industry research. I also track AI search platforms, ChatGPT, Perplexity, Google AI Overviews, for citation patterns and emerging ranking factors.</p>
      </details>
      </div>

      <div class="not-prose mt-12 bg-surface-alt border border-border rounded-[0.35rem] p-8 reveal">
        <p class="eyebrow mb-3">Get Started</p>
        <h2 class="text-2xl font-bold text-brand mb-3">Ready to Improve Your Search Visibility?</h2>
        <p class="text-text-muted mb-6 max-w-lg">I would welcome the opportunity to discuss your search objectives. No sales pitch, no obligations, simply a clear assessment of where you stand and what is achievable.</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/contact/" class="cta-button">Start with an audit</a>
          <a href="/free-seo-audit-guildford/" class="cta-button-outline">Free SEO Audit</a>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-border text-sm text-text-muted">
        <p>Explore more: <a href="/">Home</a> · <a href="/services/">Services</a> · <a href="/ai-search-optimisation-guildford/">AI Search Optimisation</a> · <a href="/case-studies/">Case Studies</a> · <a href="/areas/">Areas We Cover</a></p>
      </div>
    </div>
  </section>
  <ContactForm eyebrow="Enquire" heading="Work with me directly" subject="SEO Guildford: About page enquiry" />
</Base>
