---
import Base from '../layouts/Base.astro';

const title = "Get in Touch — SEO Guildford";
const description = "Contact SEO Guildford to start with an audit of your search performance. Serving businesses across Guildford, Surrey, and Hampshire. Email hello@seo-guildford.uk.";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://seo-guildford.uk/" },
    { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://seo-guildford.uk/contact/" }
  ]
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://seo-guildford.uk/contact/",
  "isPartOf": { "@type": "WebSite", "name": "SEO Guildford", "url": "https://seo-guildford.uk" }
};

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact SEO Guildford",
  "url": "https://seo-guildford.uk/contact/",
  "mainEntity": {
    "@type": "Organization",
    "name": "SEO Guildford",
    "url": "https://seo-guildford.uk",
    "email": "hello@seo-guildford.uk",
    "sameAs": [],
    "areaServed": [
      { "@type": "City", "name": "Guildford" },
      { "@type": "AdministrativeArea", "name": "Surrey" },
      { "@type": "AdministrativeArea", "name": "Hampshire" }
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Guildford",
      "addressRegion": "Surrey",
      "addressCountry": "GB"
    }
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you work remotely?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. SEO Guildford operates remote-first. Meetings take place via video call, reporting is shared through live dashboards, and communication is handled via email or your preferred channel. In-person meetings in Guildford, Woking, or elsewhere in Surrey can be arranged when the occasion warrants."
      }
    },
    {
      "@type": "Question",
      "name": "What areas do you cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our primary service area includes Guildford, Woking, Godalming, Farnham, Camberley, Cobham, and the wider Surrey and Hampshire corridor. Remote delivery means clients anywhere in the UK or internationally receive the same standard of work."
      }
    },
    {
      "@type": "Question",
      "name": "How quickly can we start?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most engagements begin within one week of agreement. The initial technical audit is typically delivered within the first five to seven working days, with strategic recommendations and implementation following immediately after."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer free consultations?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. An initial discovery call is always free and comes with no obligation. For a more detailed assessment, request a free SEO audit at seo-guildford.uk/free-seo-audit-guildford/ — this provides a technical and strategic overview of your site before any commitment."
      }
    }
  ]
};

const schema = [breadcrumbSchema, webPageSchema, contactPageSchema, faqSchema];
---

<Base title={title} description={description} canonical="https://seo-guildford.uk/contact/" schema={schema}>
  <section class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-text-muted mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-brand">Home</a>
      <span class="mx-1">/</span>
      <span class="text-text">Contact</span>
    </nav>

    <h1 class="text-4xl font-bold text-brand mb-6">Get in Touch</h1>

    <div class="prose">
      <div class="reveal">
      <p>Every meaningful search engagement begins the same way: a conversation. Not a sales pitch, not a templated questionnaire, but a genuine exchange about where your site stands, what the data reveals, and whether there is a clear path to better performance. We would welcome the opportunity to have that conversation with you.</p>

      <div class="quick-answer">
        <strong>The short version:</strong> Email <a href="mailto:hello@seo-guildford.uk">hello@seo-guildford.uk</a> or complete the form below. Most enquiries receive a response within 24 hours. Initial consultations are free.
      </div>
      </div>

      <div class="reveal">
      <h2>How to Reach Us</h2>

      <p>The most effective way to begin is by email — it gives us the space to consider your situation properly before responding, rather than rushing through a cold call. Send your enquiry to <a href="mailto:hello@seo-guildford.uk">hello@seo-guildford.uk</a> with a brief description of your business, your website URL, and what you are looking to achieve. You will receive a considered, personal reply — not an automated response.</p>

      <p>SEO Guildford serves businesses across the Guildford, Surrey, and Hampshire corridor. Whether your office is near Guildford High Street, based at Surrey Research Park, or operating remotely from anywhere in the UK, our service delivery model remains the same: direct access to a specialist team that does the work.</p>
      </div>
    </div>

    <form action="https://api.staticforms.xyz/submit" method="POST" class="reveal mt-8 space-y-5 bg-surface-alt rounded-xl p-6 md:p-8">
      <input type="hidden" name="accessKey" value="sf_9e906eb6c00416b9d3354749" />
      <input type="hidden" name="subject" value="SEO Guildford — New Enquiry" />
      <input type="hidden" name="redirectTo" value="https://seo-guildford.uk/contact/?sent=1" />
      <input type="text" name="honeypot" style="display:none" />
      <div>
        <label for="name" class="block text-sm font-medium text-text mb-1.5">Name <span class="text-red-500">*</span></label>
        <input type="text" id="name" name="name" required autocomplete="name" class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-text placeholder:text-text-muted/50 focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none transition" placeholder="Your name" />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-text mb-1.5">Email <span class="text-red-500">*</span></label>
        <input type="email" id="email" name="email" required autocomplete="email" class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-text placeholder:text-text-muted/50 focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none transition" placeholder="you@company.co.uk" />
      </div>

      <div>
        <label for="website" class="block text-sm font-medium text-text mb-1.5">Website URL</label>
        <input type="url" id="website" name="website" autocomplete="url" class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-text placeholder:text-text-muted/50 focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none transition" placeholder="https://yoursite.co.uk" />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-text mb-1.5">Message <span class="text-red-500">*</span></label>
        <textarea id="message" name="message" required rows="5" class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-text placeholder:text-text-muted/50 focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none transition resize-y" placeholder="Tell us about your business and what you are looking to achieve with search."></textarea>
      </div>

      <button type="submit" class="cta-button w-full sm:w-auto">Start with an audit</button>
    </form>

    <div class="prose mt-12 reveal">
      <h2>Where We Are</h2>

      <p>SEO Guildford is based in Guildford, Surrey. The map below shows the town centre. Meetings can be arranged at a location convenient to you, or conducted remotely via video call.</p>
    </div>

    <div class="reveal mt-6 rounded-xl overflow-hidden border border-border">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2504.9!2d-0.5735!3d51.2362!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4875d0a9463bda73%3A0x38a33d4d72580e8!2sGuildford!5e0!3m2!1sen!2suk!4v1"
        width="100%"
        height="350"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Map showing Guildford town centre, Surrey"
      ></iframe>
    </div>

    <div class="prose mt-12">
      <div class="reveal">
      <h2>Areas We Cover</h2>

      <p>SEO Guildford provides search consultancy services across the Surrey and Hampshire corridor, including Guildford, Woking, Godalming, Farnham, Camberley, Cobham, Esher, and Weybridge. For a full breakdown of service areas with local information, visit the <a href="/areas/">areas page</a>.</p>
      </div>

      <div class="reveal">
      <h2>Frequently Asked Questions</h2>

      <details class="faq-item">
        <summary>Do you work remotely?</summary>
        <p>Yes. SEO Guildford operates remote-first. Meetings take place via video call, reporting is shared through live dashboards, and communication is handled via email or your preferred channel. In-person meetings in Guildford, Woking, or elsewhere in Surrey can be arranged when the occasion warrants.</p>
      </details>

      <details class="faq-item">
        <summary>What areas do you cover?</summary>
        <p>Our primary service area includes Guildford, Woking, Godalming, Farnham, Camberley, Cobham, and the wider Surrey and Hampshire corridor. Remote delivery means clients anywhere in the UK or internationally receive the same standard of work.</p>
      </details>

      <details class="faq-item">
        <summary>How quickly can we start?</summary>
        <p>Most engagements begin within one week of agreement. The initial technical audit is typically delivered within the first five to seven working days, with strategic recommendations and implementation following immediately after.</p>
      </details>

      <details class="faq-item">
        <summary>Do you offer free consultations?</summary>
        <p>Yes. An initial discovery call is always free and carries no obligation. For a more detailed assessment, request a <a href="/free-seo-audit-guildford/">free SEO audit</a> — this provides a technical and strategic overview of your site before any commitment.</p>
      </details>
      </div>

      <div class="not-prose mt-12 bg-surface-alt rounded-xl p-8 text-center reveal">
        <h2 class="text-2xl font-bold text-brand mb-3">Prefer Email?</h2>
        <p class="text-text-muted mb-6 max-w-lg mx-auto">Send your enquiry directly and receive a personal response from our team within 24 hours.</p>
        <a href="mailto:hello@seo-guildford.uk" class="cta-button">Email hello@seo-guildford.uk</a>
      </div>

      <div class="mt-8 pt-6 border-t border-border text-sm text-text-muted">
        <p>Explore more: <a href="/">Home</a> · <a href="/services/">Services</a> · <a href="/free-seo-audit-guildford/">Free SEO Audit</a> · <a href="/areas/">Areas We Cover</a></p>
      </div>
    </div>
  </section>
</Base>
