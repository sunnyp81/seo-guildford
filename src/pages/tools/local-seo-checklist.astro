  <!-- Inline JS -->
  <script>
    (function() {
      const STORAGE_KEY = 'seo-guildford-checklist';
      const TOTAL = 20;
      const categoryCounts = { gbp: 5, onpage: 4, technical: 4, reviews: 3, citations: 4 };

      function loadState() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          return raw ? JSON.parse(raw) : {};
        } catch { return {}; }
      }

      function saveState(state) {
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
      }

      function updateProgress(state) {
        const checked = Object.values(state).filter(Boolean).length;
        const pct = Math.round((checked / TOTAL) * 100);
        const bar = document.getElementById('progress-bar');
        const label = document.getElementById('progress-label');
        if (bar) bar.style.width = pct + '%';
        if (label) label.textContent = checked + ' / ' + TOTAL;

        // Category sub-progress
        Object.keys(categoryCounts).forEach(function(cat) {
          const total = categoryCounts[cat];
          const items = document.querySelectorAll('.checklist-item[data-category="' + cat + '"]');
          let done = 0;
          items.forEach(function(item) {
            const id = item.getAttribute('data-id');
            if (state[id]) done++;
          });
          const el = document.querySelector('[data-category-count="' + cat + '"]');
          if (el) el.textContent = done + ' / ' + total;
        });

        // Visual feedback on checked items
        document.querySelectorAll('.checklist-item').forEach(function(item) {
          const id = item.getAttribute('data-id');
          const label = item.querySelector('.checklist-label');
          if (state[id]) {
            item.classList.add('border-accent/30');
            if (label) label.classList.add('line-through', 'opacity-60');
          } else {
            item.classList.remove('border-accent/30');
            if (label) label.classList.remove('line-through', 'opacity-60');
          }
        });
      }

      function init() {
        var state = loadState();

        // Restore checkbox states
        document.querySelectorAll('.checklist-item').forEach(function(item) {
          var id = item.getAttribute('data-id');
          var cb = item.querySelector('.checklist-checkbox');
          if (cb && state[id]) cb.checked = true;
        });

        updateProgress(state);

        // Listen for changes
        document.querySelectorAll('.checklist-checkbox').forEach(function(cb) {
          cb.addEventListener('change', function() {
            var item = cb.closest('.checklist-item');
            var id = item.getAttribute('data-id');
            var state = loadState();
            state[id] = cb.checked;
            saveState(state);
            updateProgress(state);
          });
        });

        // Reset button
        var resetBtn = document.getElementById('reset-btn');
        if (resetBtn) {
          resetBtn.addEventListener('click', function() {
            if (!confirm('Reset all checklist progress?')) return;
            localStorage.removeItem(STORAGE_KEY);
            document.querySelectorAll('.checklist-checkbox').forEach(function(cb) { cb.checked = false; });
            updateProgress({});
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>

