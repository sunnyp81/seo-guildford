---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';

const title = "SEO Guildford: Local Search Marketing for Surrey";
const description = "SEO Guildford delivers technical SEO, content strategy, and AI search optimisation for Guildford and Surrey businesses. Start with a free audit today.";

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "SEO Guildford",
  "url": "https://seo-guildford.uk",
  "email": "hello@seo-guildford.uk",
  "sameAs": ["https://find-and-update.company-information.service.gov.uk/company/10784524"],
  "areaServed": [
    { "@type": "City", "name": "Guildford" },
    { "@type": "AdministrativeArea", "name": "Surrey" },
    "Onslow Village", "Burpham", "Merrow", "Stoughton", "Park Barn",
    "Bellfields", "Westborough", "Pewley Hill", "Charlotteville", "Shalford"
  ]
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "SEO Guildford",
  "url": "https://seo-guildford.uk",
  "email": "hello@seo-guildford.uk",
  "priceRange": "£££",
  "sameAs": ["https://find-and-update.company-information.service.gov.uk/company/10784524"],
  "areaServed": [
    { "@type": "City", "name": "Guildford" },
    { "@type": "AdministrativeArea", "name": "Surrey" }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://seo-guildford.uk/" }
  ]
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://seo-guildford.uk/",
  "isPartOf": { "@type": "WebSite", "name": "SEO Guildford", "url": "https://seo-guildford.uk" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does SEO cost in Guildford?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SEO services in Guildford typically range from £500 to £3,500 per month, depending on the level of competition, the number of target keywords, and the overall scope of work involved. Guildford's affluent market and its competitive industries, technology, property, and professional services among them, often require sustained investment before meaningful results materialise. See my pricing page for detailed options."
      }
    },
    {
      "@type": "Question",
      "name": "How long does SEO take to work for a Guildford business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most Guildford businesses observe measurable ranking improvements within 3 to 6 months, though local SEO results, such as improved Google Business Profile visibility near Guildford High Street or the Friary Centre, can appear sooner, often within 4 to 8 weeks. Technical remediation, such as resolving crawl errors or improving Core Web Vitals, can have near-immediate impact on indexation, like clearing a blocked pipe to restore flow."
      }
    },
    {
      "@type": "Question",
      "name": "Do you work with businesses outside Guildford?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "I do. While Guildford is my home base, I serve clients across Surrey including Woking, Godalming, Farnham, Camberley, Cobham, and the wider South East. Many clients at Surrey Research Park and Slyfield Industrial Estate also serve national markets, and I build SEO strategies that address both local and broader search visibility with equal care."
      }
    },
    {
      "@type": "Question",
      "name": "What is local SEO and why does it matter in Guildford?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Local SEO optimises your business to appear in location-based searches, for instance, when someone near Guildford Cathedral or the University of Surrey searches for your services. With average property prices above £600,000, Guildford consumers demonstrate high purchasing intent, which makes local visibility particularly valuable. Local SEO encompasses Google Business Profile, local citations, map pack rankings, and location-specific content."
      }
    },
    {
      "@type": "Question",
      "name": "Can you help with AI search optimisation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Indeed. AI-powered search engines such as Google AI Overviews, ChatGPT, and Perplexity are changing how people find businesses in fundamental ways. I optimise your content to be cited by these systems, ensuring your Guildford business appears in AI-generated answers alongside traditional search results. Read more on my AI search optimisation page."
      }
    },
    {
      "@type": "Question",
      "name": "What industries do you specialise in?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "I work extensively with Guildford's strongest sectors: gaming and technology companies near Surrey Research Park, professional services firms along the High Street, healthcare providers including those near Royal Surrey County Hospital, property agents, and finance businesses serving the affluent Surrey market. See my industries page for further detail."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer free SEO audits?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "I do. My free SEO audit covers technical health, keyword opportunities, and competitor analysis specific to your position in the Guildford market. Think of it as a surveyor's report for your digital presence, it reveals the structural condition before you invest in renovation. Request your audit."
      }
    },
    {
      "@type": "Question",
      "name": "What makes SEO Guildford different from other agencies?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SEO Guildford is a specialist consultancy, not a generalist agency. Every strategy is built around Guildford's local market dynamics, from Surrey Research Park's technology corridor to the professional services cluster around Castle Street. I combine technical SEO, semantic content, and AI search readiness in a single, craft-driven service, with direct access to me, the person doing the work, rather than layers of account management."
      }
    },
    {
      "@type": "Question",
      "name": "What does a typical SEO campaign for a Guildford business include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A typical SEO campaign for a Guildford business covers technical fixes, keyword research, on-page and service-page optimisation, content improvements, internal linking, Google Business Profile management, and citation and outreach work to build authority. The exact mix depends on whether a business needs local visibility, national reach, or both."
      }
    },
    {
      "@type": "Question",
      "name": "What should I look for when choosing an SEO consultant in Guildford?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Look for local market knowledge, transparent pricing with no hidden costs, and a clear explanation of what work will be carried out and why. Providers offering guaranteed rankings or quick fixes through techniques like keyword stuffing or link farming should be treated with caution, since these tactics carry a real risk of manual action from Google."
      }
    }
  ]
};

const schema = [orgSchema, localBusinessSchema, breadcrumbSchema, webPageSchema, faqSchema];
---
<Base title={title} description={description} schema={schema}>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow hero-eyebrow">Technical SEO &middot; Guildford, Surrey</p>
      <h1 class="hero-title">Rank, convert, and <span class="mark">dominate</span> Guildford search.</h1>
      <p class="hero-lead">Technical SEO, semantic content, and AI search readiness, engineered into organic growth that compounds month after month.</p>
      <div class="hero-actions">
        <a href="/free-seo-audit-guildford/" class="cta-button">Request a free audit</a>
        <a href="/services/" class="cta-button-outline">Explore services</a>
      </div>
      <p class="cta-note">Free and without obligation. A reply within one working day.</p>
    </div>
    <div class="hero-spec">
      <div class="hero-spec-grid">
        <div class="spec reveal">
          <span class="spec-k">I</span>
          <span class="spec-v">Technical SEO</span>
          <span class="spec-d">Crawlability, speed, schema, indexation</span>
        </div>
        <div class="spec reveal" style="--reveal-delay: 0.08s">
          <span class="spec-k">II</span>
          <span class="spec-v">Semantic content</span>
          <span class="spec-d">Topical authority and entity depth</span>
        </div>
        <div class="spec reveal" style="--reveal-delay: 0.16s">
          <span class="spec-k">III</span>
          <span class="spec-v">AI search</span>
          <span class="spec-d">AI Overviews, ChatGPT, Perplexity</span>
        </div>
      </div>
    </div>
  </section>

  <article class="max-w-3xl mx-auto px-4 py-12 md:py-16 prose">

    <p class="reveal text-lg text-text mb-8">SEO Guildford is a specialist, solo consultancy combining technical SEO, semantic content, and AI search optimisation for businesses across Guildford and Surrey. One practitioner, one plan, no account managers.</p>

    <div class="reveal" style="--reveal-delay: 0.1s">
      <div class="quick-answer">
        <strong>The short version:</strong> SEO Guildford is a specialist SEO consultancy serving businesses across Guildford and Surrey, combining technical SEO, content strategy, and AI search optimisation into a single service. It covers technical audits, semantic content architecture, local SEO, and AEO/GEO work aimed at securing citations from Google AI Overviews, ChatGPT, and Perplexity. <a href="/free-seo-audit-guildford/">A free SEO audit</a> is the standard starting point.
      </div>
    </div>

    <h2 class="reveal">Why work with me</h2>
    <div class="grid sm:grid-cols-2 gap-5 not-prose my-8">
      <div class="service-card reveal">
        <span class="eyebrow">01</span>
        <h3 class="font-heading text-brand text-lg mt-2 mb-1.5">Technical foundations first</h3>
        <p class="text-text-muted text-sm m-0">Crawlability, speed, indexation, and schema fixed before content, because rankings sit on infrastructure.</p>
      </div>
      <div class="service-card reveal" style="--reveal-delay: 0.06s">
        <span class="eyebrow">02</span>
        <h3 class="font-heading text-brand text-lg mt-2 mb-1.5">One specialist, direct</h3>
        <p class="text-text-muted text-sm m-0">No account managers or junior hand-offs. The person who diagnoses the problem is the person who fixes it.</p>
      </div>
      <div class="service-card reveal" style="--reveal-delay: 0.12s">
        <span class="eyebrow">03</span>
        <h3 class="font-heading text-brand text-lg mt-2 mb-1.5">Built for AI search</h3>
        <p class="text-text-muted text-sm m-0">AEO and GEO work so you are cited by Google AI Overviews, ChatGPT, and Perplexity, not just ranked in blue links.</p>
      </div>
      <div class="service-card reveal" style="--reveal-delay: 0.18s">
        <span class="eyebrow">04</span>
        <h3 class="font-heading text-brand text-lg mt-2 mb-1.5">Local Surrey knowledge</h3>
        <p class="text-text-muted text-sm m-0">From Surrey Research Park to the High Street, strategy built on the real Guildford market, not a generic template.</p>
      </div>
      <div class="service-card reveal" style="--reveal-delay: 0.24s">
        <span class="eyebrow">05</span>
        <h3 class="font-heading text-brand text-lg mt-2 mb-1.5">Transparent pricing</h3>
        <p class="text-text-muted text-sm m-0">Fixed-fee and retainer options, no hidden costs and no lock-in contracts.</p>
      </div>
      <div class="service-card reveal" style="--reveal-delay: 0.3s">
        <span class="eyebrow">06</span>
        <h3 class="font-heading text-brand text-lg mt-2 mb-1.5">Free audit first</h3>
        <p class="text-text-muted text-sm m-0">See exactly where you stand before committing anything, at no cost and no obligation.</p>
      </div>
    </div>

    <h2 class="reveal">My SEO Services</h2>

    <p class="reveal">Every engagement begins with an honest assessment of where you are and where you need to be, a surveyor's first reading before any construction begins. My <a href="/services/">services</a> span the full spectrum of search marketing, each calibrated to the competitive realities of the Guildford market.</p>

    <div class="grid md:grid-cols-2 gap-6 not-prose my-10">
      <a href="/technical-seo-guildford/" class="service-card block reveal">
        <h3 class="font-bold text-brand text-lg mb-2 font-heading">Technical SEO</h3>
        <p class="text-text-muted text-sm">Site speed, crawlability, Core Web Vitals, indexation, and structured data, the load-bearing foundation upon which everything else depends.</p>
      </a>
      <a href="/seo-audit-guildford/" class="service-card block reveal" style="--reveal-delay: 0.08s">
        <h3 class="font-bold text-brand text-lg mb-2 font-heading">SEO Audit</h3>
        <p class="text-text-muted text-sm">A thorough analysis of technical health, content gaps, backlink profile, and competitive positioning within the Guildford market.</p>
      </a>
      <a href="/ai-search-optimisation-guildford/" class="service-card block reveal" style="--reveal-delay: 0.16s">
        <h3 class="font-bold text-brand text-lg mb-2 font-heading">AI Search Optimisation</h3>
        <p class="text-text-muted text-sm">Ensure your business is cited by ChatGPT, Google AI Overviews, and Perplexity, the emerging frontier where search meets machine intelligence.</p>
      </a>
      <a href="/services/" class="service-card block reveal" style="--reveal-delay: 0.24s">
        <h3 class="font-bold text-brand text-lg mb-2 font-heading">Content Strategy</h3>
        <p class="text-text-muted text-sm">Topical authority mapping, semantic content, and editorial calendars that build compounding organic traffic, like a well-tended garden that yields more each season.</p>
      </a>
      <a href="/free-seo-audit-guildford/" class="service-card block reveal" style="--reveal-delay: 0.32s">
        <h3 class="font-bold text-brand text-lg mb-2 font-heading">Free SEO Audit</h3>
        <p class="text-text-muted text-sm">A considered review of your site's technical health, keyword opportunities, and competitive landscape, provided without obligation.</p>
      </a>
      <a href="/seo-pricing-guildford/" class="service-card block reveal" style="--reveal-delay: 0.4s">
        <h3 class="font-bold text-brand text-lg mb-2 font-heading">SEO Pricing</h3>
        <p class="text-text-muted text-sm">Transparent pricing for Guildford businesses, with both fixed-fee and retainer arrangements to suit different requirements and objectives.</p>
      </a>
    </div>

    <h2 class="reveal">Industries I serve</h2>
    <p class="reveal text-text-muted mb-6">Guildford's economy is unusually diverse, so each sector gets its own approach rather than a single template.</p>
    <div class="grid sm:grid-cols-2 gap-5 not-prose my-8">
      <a href="/industries/" class="service-card block reveal">
        <span class="eyebrow">Gaming &amp; Technology</span>
        <p class="text-text-muted text-sm mt-2 m-0">Studios like Media Molecule plus Surrey Research Park's AI, biotech, and software firms, competing nationally on complex site architectures.</p>
      </a>
      <a href="/industries/" class="service-card block reveal" style="--reveal-delay: 0.06s">
        <span class="eyebrow">Professional Services</span>
        <p class="text-text-muted text-sm mt-2 m-0">Solicitors, accountants, and advisers around the High Street and Tunsgate Quarter competing for high-intent local searches.</p>
      </a>
      <a href="/industries/" class="service-card block reveal" style="--reveal-delay: 0.12s">
        <span class="eyebrow">Property &amp; Construction</span>
        <p class="text-text-muted text-sm mt-2 m-0">Estate agents and developers in a market averaging over £600,000, targeting location and buying-intent queries.</p>
      </a>
      <a href="/industries/" class="service-card block reveal" style="--reveal-delay: 0.18s">
        <span class="eyebrow">Healthcare</span>
        <p class="text-text-muted text-sm mt-2 m-0">Practices near Royal Surrey County Hospital where YMYL content demands real E-E-A-T and patient trust signals.</p>
      </a>
    </div>

    <h2 class="reveal">Areas I cover</h2>
    <p class="reveal text-text-muted mb-4">Based in Guildford, working across Surrey and the surrounding towns.</p>
    <div class="not-prose flex flex-wrap gap-2 mb-5 reveal">
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Guildford</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Onslow Village</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Burpham</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Merrow</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Stoughton</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Park Barn</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Bellfields</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Westborough</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Pewley Hill</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Charlotteville</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Shalford</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Woking</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Godalming</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Farnham</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Camberley</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Cobham</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Esher</span>
      <span class="border border-border rounded px-3 py-1 text-sm text-text-muted">Weybridge</span>
    </div>
    <p class="reveal"><a href="/areas/">See all areas I cover</a> for local SEO detail by location.</p>

    <h2 class="reveal">How I Work</h2>

    <p class="reveal">Every engagement follows a structured process designed to produce measurable results without misallocating time or budget. Think of it as building a house: you survey the site, draw the plans, lay the foundations, then build upward, never the reverse.</p>

    <div class="process-timeline not-prose my-10">
      <div class="process-step reveal">
        <span class="step-number">01</span>
        <div>
          <h3 class="font-bold text-brand text-lg mb-2 font-heading">Discovery & Audit</h3>
          <p class="text-text-muted text-sm leading-relaxed">I analyse your current search performance, technical health, content inventory, and competitive landscape. For Guildford businesses, this includes mapping your visibility against local competitors and identifying gaps in both the local pack and organic results that represent genuine commercial opportunity.</p>
        </div>
      </div>
      <div class="process-step reveal" style="--reveal-delay: 0.1s">
        <span class="step-number">02</span>
        <div>
          <h3 class="font-bold text-brand text-lg mb-2 font-heading">Strategy</h3>
          <p class="text-text-muted text-sm leading-relaxed">Based on the audit findings, I build a prioritised roadmap reflecting both impact and effort. Technical remediation comes first, there is little value in publishing content on a site that search engines cannot properly crawl or index. Content strategy, local SEO, and link building are then layered according to the returns each is likely to deliver.</p>
        </div>
      </div>
      <div class="process-step reveal" style="--reveal-delay: 0.2s">
        <span class="step-number">03</span>
        <div>
          <h3 class="font-bold text-brand text-lg mb-2 font-heading">Execution</h3>
          <p class="text-text-muted text-sm leading-relaxed">I implement changes directly or work in close coordination with your development team. Monthly reporting tracks keyword rankings, organic traffic, conversions, and revenue attribution, ensuring that every action ties back to commercial outcomes rather than vanity metrics.</p>
        </div>
      </div>
      <div class="process-step reveal" style="--reveal-delay: 0.3s">
        <span class="step-number">04</span>
        <div>
          <h3 class="font-bold text-brand text-lg mb-2 font-heading">Optimisation</h3>
          <p class="text-text-muted text-sm leading-relaxed">Search is not static, and a well-crafted strategy must evolve alongside it. Algorithm updates, competitor activity, and shifting user behaviour all require ongoing, measured adjustment, the way a gardener prunes and feeds through the seasons. I monitor Google Search Console, analytics, and AI search citations to keep your strategy current.</p>
        </div>
      </div>
    </div>

    <div class="reveal">
      <h2>Results That Matter</h2>

      <p>I measure success in revenue impact, not in metrics that merely flatter. Rankings matter only when they drive qualified traffic that converts into genuine business. My <a href="/case-studies/">case studies</a> illustrate how Guildford businesses have grown organic revenue through targeted SEO, from local service firms achieving map pack prominence to technology companies capturing national search demand from their Surrey base.</p>

      <p>Every client receives monthly reporting with clear, substantive metrics: organic sessions, keyword movements, conversion rates, and projected revenue impact. I set expectations candidly and hold myself accountable to them.</p>
    </div>

    <div class="reveal">
      <h2>The Guildford SEO Landscape</h2>

      <p>Guildford sits at a strategic intersection that shapes its commercial character in distinctive ways. Close enough to London to attract commuter wealth, yet far enough to sustain a self-sufficient local economy, it occupies a position not unlike a river confluence, where different currents of commerce meet and create something richer than any single stream. The town's blend of heritage, Guildford Castle, the Cathedral on Stag Hill, the River Wey navigation, and modernity, the Spectrum leisure complex, Stoke Park redevelopment, the technology corridor, creates a market where both traditional and digital-first businesses compete for the attention of an unusually discerning audience.</p>

      <p>Search behaviour in Guildford reflects this duality with considerable nuance. A solicitor on Castle Street needs to rank for "solicitor guildford" in the local pack. A SaaS company at Surrey Research Park needs to rank for industry terms nationally. A restaurant near the Yvonne Arnaud Theatre needs to appear in "near me" searches from theatregoers making last-minute decisions. A single, undifferentiated approach to SEO simply does not serve this market, which is precisely why a craft-driven approach matters here more than most places.</p>

      <p>AI search is introducing yet another layer of complexity that rewards those who prepare for it. Google AI Overviews now appear for many local queries, while ChatGPT and Perplexity are becoming meaningful discovery tools for high-consideration purchases, precisely the kind of purchases that Guildford's affluent population tends to make. Businesses that overlook AI search optimisation risk ceding ground to competitors who adapt with greater purpose and foresight.</p>
    </div>

    <h2 class="reveal">Frequently Asked Questions</h2>

    <div class="not-prose reveal">
      <details class="faq-item">
        <summary>How much does SEO cost in Guildford?</summary>
        <div class="faq-answer">
          <p>SEO services in Guildford typically range from £500 to £3,500 per month, depending on the level of competition, the number of target keywords, and the overall scope of work involved. Guildford's affluent market and its competitive industries, technology, property, and professional services among them, often require sustained investment before meaningful results materialise. See my <a href="/seo-pricing-guildford/">pricing page</a> for detailed options.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary>How long does SEO take to work for a Guildford business?</summary>
        <div class="faq-answer">
          <p>Most Guildford businesses observe measurable ranking improvements within 3 to 6 months, though local SEO results, such as improved Google Business Profile visibility near Guildford High Street or the Friary Centre, can appear sooner, often within 4 to 8 weeks. Technical remediation, such as resolving crawl errors or improving Core Web Vitals, can have near-immediate impact on indexation, like clearing a blocked pipe to restore flow.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary>Do you work with businesses outside Guildford?</summary>
        <div class="faq-answer">
          <p>I do. While Guildford is my home base, I serve clients across Surrey including Woking, Godalming, Farnham, Camberley, Cobham, and the wider South East. Many clients at Surrey Research Park and Slyfield Industrial Estate also serve national markets, and I build SEO strategies that address both local and broader search visibility with equal care.</p>
        </div>
      </details>

