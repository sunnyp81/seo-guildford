---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found — SEO Guildford" description="The page you're looking for doesn't exist. Return to SEO Guildford for local search marketing services in Surrey.">
  <div class="max-w-3xl mx-auto px-4 py-24 text-center">
    <h1 class="text-4xl font-bold text-brand mb-4">Page Not Found</h1>
    <p class="text-text-muted text-lg mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="cta-button">Back to Home</a>
      <a href="/contact/" class="cta-button-outline">Contact Us</a>
    </div>
  </div>
</Base>
